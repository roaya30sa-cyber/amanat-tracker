{
  "name": "amanat-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant Arabic project tracking app — Saudi regional projects office (Jazan / Eastern / Northern)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:dev": "npm run pages:build && wrangler pages dev .vercel/output/static --d1=DB=projects-tracker",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "db:init": "wrangler d1 execute projects-tracker --local --file=./migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute projects-tracker --remote --file=./migrations/0001_init.sql",
    "db:seed": "wrangler d1 execute projects-tracker --local --file=./migrations/0002_seed.sql",
    "db:seed:remote": "wrangler d1 execute projects-tracker --remote --file=./migrations/0002_seed.sql",
    "import:csv": "tsx scripts/import-from-sheets.ts"
  },
  "dependencies": {
    "@auth/core": "^0.34.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.452.0",
    "next": "14.2.15",
    "next-auth": "5.0.0-beta.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.4",
    "@cloudflare/workers-types": "^4.20241011.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "csv-parse": "^5.5.6",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vercel": "^37.6.1",
    "wrangler": "^3.80.4"
  }
}
